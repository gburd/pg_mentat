# pg_mentat Docker Compose configuration
# Copy this file to .env and edit as needed:
#   cp docker/.env.example docker/.env

# ---- PostgreSQL ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mentat
PG_PORT=5432

# Resource limits (compose deploy)
PG_CPU_LIMIT=2
PG_MEM_LIMIT=1g

# ---- mentatd HTTP server ----
MENTATD_PORT=8080

# Logging (trace, debug, info, warn, error)
RUST_LOG=info
LOG_FORMAT=compact

# Connection pool
DATABASE_POOL_SIZE=10
DATABASE_MAX_LIFETIME=1800

# Query cache
MENTATD_CACHE_ENABLED=true
MENTATD_CACHE_CAPACITY=1000
MENTATD_CACHE_TTL=300

# Resource limits
MENTATD_CPU_LIMIT=1
MENTATD_MEM_LIMIT=512m
