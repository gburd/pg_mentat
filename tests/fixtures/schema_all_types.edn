;; Schema fixture: one attribute for each of the 9 Datomic value types.
;; Also includes cardinality-many and unique-identity variants.
;;
;; Usage:
;;   SELECT mentat_transact(pg_read_file('/path/to/schema_all_types.edn'));

[
  ;; Cardinality-one attributes, one per value type
  {:db/id "r"   :db/ident :test/ref      :db/valueType :db.type/ref      :db/cardinality :db.cardinality/one}
  {:db/id "b"   :db/ident :test/bool     :db/valueType :db.type/boolean  :db/cardinality :db.cardinality/one}
  {:db/id "l"   :db/ident :test/long     :db/valueType :db.type/long     :db/cardinality :db.cardinality/one}
  {:db/id "d"   :db/ident :test/double   :db/valueType :db.type/double   :db/cardinality :db.cardinality/one}
  {:db/id "s"   :db/ident :test/string   :db/valueType :db.type/string   :db/cardinality :db.cardinality/one}
  {:db/id "k"   :db/ident :test/keyword  :db/valueType :db.type/keyword  :db/cardinality :db.cardinality/one}
  {:db/id "i"   :db/ident :test/instant  :db/valueType :db.type/instant  :db/cardinality :db.cardinality/one}
  {:db/id "u"   :db/ident :test/uuid     :db/valueType :db.type/uuid     :db/cardinality :db.cardinality/one}
  {:db/id "by"  :db/ident :test/bytes    :db/valueType :db.type/bytes    :db/cardinality :db.cardinality/one}

  ;; Cardinality-many
  {:db/id "tags" :db/ident :test/tags    :db/valueType :db.type/string   :db/cardinality :db.cardinality/many}
  {:db/id "refs" :db/ident :test/refs    :db/valueType :db.type/ref      :db/cardinality :db.cardinality/many}

  ;; Unique identity (triggers upsert)
  {:db/id "uid"  :db/ident :test/uid     :db/valueType :db.type/string   :db/cardinality :db.cardinality/one :db/unique :db.unique/identity}

  ;; Unique value (rejects duplicates)
  {:db/id "code" :db/ident :test/code    :db/valueType :db.type/string   :db/cardinality :db.cardinality/one :db/unique :db.unique/value}

  ;; Fulltext
  {:db/id "bio"  :db/ident :test/bio     :db/valueType :db.type/string   :db/cardinality :db.cardinality/one :db/fulltext true}

  ;; Indexed
  {:db/id "idx"  :db/ident :test/indexed  :db/valueType :db.type/long    :db/cardinality :db.cardinality/one :db/index true}

  ;; Component
  {:db/id "comp" :db/ident :test/child    :db/valueType :db.type/ref     :db/cardinality :db.cardinality/one :db/isComponent true}
]
