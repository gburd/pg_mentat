;; Schema fixture: social network domain for testing refs, pulls, and graphs.
;;
;; Usage:
;;   SELECT mentat_transact(pg_read_file('/path/to/schema_social.edn'));

[
  {:db/id "n"   :db/ident :person/name    :db/valueType :db.type/string   :db/cardinality :db.cardinality/one :db/unique :db.unique/identity}
  {:db/id "a"   :db/ident :person/age     :db/valueType :db.type/long     :db/cardinality :db.cardinality/one}
  {:db/id "e"   :db/ident :person/email   :db/valueType :db.type/string   :db/cardinality :db.cardinality/one :db/unique :db.unique/value}
  {:db/id "f"   :db/ident :person/friends :db/valueType :db.type/ref      :db/cardinality :db.cardinality/many}
  {:db/id "m"   :db/ident :person/mentor  :db/valueType :db.type/ref      :db/cardinality :db.cardinality/one}
  {:db/id "t"   :db/ident :person/tags    :db/valueType :db.type/string   :db/cardinality :db.cardinality/many}
  {:db/id "ac"  :db/ident :person/active  :db/valueType :db.type/boolean  :db/cardinality :db.cardinality/one}
  {:db/id "bio" :db/ident :person/bio     :db/valueType :db.type/string   :db/cardinality :db.cardinality/one :db/fulltext true}
]
